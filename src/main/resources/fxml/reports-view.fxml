<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/21"
      fx:controller="controller.ReportsController" spacing="20.0" styleClass="page">
    <padding>
        <Insets top="28.0" right="28.0" bottom="28.0" left="28.0"/>
    </padding>
    <Label text="Relatórios" styleClass="section-title"/>
    <Label text="Exporte seus dados em CSV, PDF ou JSON" styleClass="section-subtitle"/>

    <VBox spacing="16.0" styleClass="card" maxWidth="520.0">
        <Label text="Exportações disponíveis" styleClass="section-title"/>
        <Label text="Escolha o formato e o destino do arquivo." styleClass="body-text" wrapText="true"/>
        <Button text="Exportar fluxo de caixa (CSV)" onAction="#onExportCashFlowCsv" maxWidth="Infinity"/>
        <Button text="Exportar movimentações (CSV)" onAction="#onExportMovementsCsv" maxWidth="Infinity"/>
        <Button text="Exportar fluxo de caixa (PDF)" onAction="#onExportCashFlowPdf" maxWidth="Infinity"/>
        <Button text="Exportar dados (JSON)" styleClass="ghost-button" onAction="#onExportJson" maxWidth="Infinity"/>
        <Button text="Importar dados (JSON)" styleClass="ghost-button" onAction="#onImportJson" maxWidth="Infinity"/>
        <Label fx:id="statusLabel" styleClass="muted-label" wrapText="true"/>
    </VBox>
</VBox>
