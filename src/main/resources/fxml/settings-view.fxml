<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/21"
      fx:controller="controller.SettingsController" spacing="20.0" styleClass="page"
      maxWidth="Infinity" maxHeight="Infinity">
    <padding>
        <Insets top="28.0" right="72.0" bottom="28.0" left="28.0"/>
    </padding>
    <Label text="Configurações" styleClass="section-title"/>
    <Label text="Preferências da interface e do sistema" styleClass="section-subtitle"/>

    <VBox spacing="16.0" styleClass="card" maxWidth="640.0">
        <Label text="Aparência" styleClass="section-title"/>
        <Label text="Escolha o tema da aplicação. A preferência é salva automaticamente."
               styleClass="body-text" wrapText="true"/>
        <HBox spacing="12.0">
            <Button fx:id="darkThemeButton" text="Escuro (Dark)" styleClass="theme-option"
                    onAction="#onSelectDark" maxWidth="Infinity" HBox.hgrow="ALWAYS"
                    mnemonicParsing="false"/>
            <Button fx:id="lightThemeButton" text="Claro (White)" styleClass="theme-option"
                    onAction="#onSelectLight" maxWidth="Infinity" HBox.hgrow="ALWAYS"
                    mnemonicParsing="false"/>
        </HBox>
        <Label fx:id="themeStatusLabel" styleClass="muted-label"/>
    </VBox>

    <VBox spacing="14.0" styleClass="card" maxWidth="640.0">
        <Label text="Backup" styleClass="section-title"/>
        <CheckBox fx:id="autoBackupCheck" text="Backup automático ao iniciar o sistema"
                  onAction="#onToggleAutoBackup"/>
        <Label fx:id="backupStatusLabel" styleClass="muted-label" wrapText="true"/>
    </VBox>
</VBox>
