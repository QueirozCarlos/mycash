<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/21"
      fx:controller="controller.BackupController" spacing="20.0" styleClass="page">
    <padding>
        <Insets top="28.0" right="28.0" bottom="28.0" left="28.0"/>
    </padding>
    <Label text="Backup e restauração" styleClass="section-title"/>
    <Label text="Proteja seus dados com cópias locais do banco SQLite" styleClass="section-subtitle"/>

    <VBox spacing="14.0" styleClass="card" maxWidth="720.0" VBox.vgrow="ALWAYS">
        <CheckBox fx:id="autoBackupCheck" text="Backup automático ao iniciar o sistema" onAction="#onToggleAutoBackup"/>
        <HBox spacing="10.0">
            <Button text="Criar backup agora" onAction="#onCreateBackup"/>
            <Button text="Atualizar lista" styleClass="ghost-button" onAction="#onRefresh"/>
            <Button text="Restaurar selecionado" styleClass="danger-button" onAction="#onRestore"/>
        </HBox>
        <Label text="Backups disponíveis" styleClass="form-label"/>
        <ListView fx:id="backupList" VBox.vgrow="ALWAYS" prefHeight="360.0"/>
        <Label fx:id="statusLabel" styleClass="muted-label" wrapText="true"/>
    </VBox>
</VBox>
