<?xml version="1.0" encoding="UTF-8"?>
<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd"
             version="3.0">
    <persistence-unit name="financeiroPU" transaction-type="RESOURCE_LOCAL">
        <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>
        <class>model.UserEntity</class>
        <class>model.CategoryEntity</class>
        <class>model.MovementEntity</class>
        <class>model.RecurringAccountEntity</class>
        <class>model.CreditCardEntity</class>
        <class>model.InstallmentPlanEntity</class>
        <class>model.GoalEntity</class>
        <class>model.LocalDateTimeAttributeConverter</class>
        <class>model.LocalDateAttributeConverter</class>
        <properties>
            <property name="hibernate.show_sql" value="false"/>
            <property name="hibernate.format_sql" value="true"/>
            <property name="hibernate.hbm2ddl.auto" value="none"/>
        </properties>
    </persistence-unit>
</persistence>
